ATLASSIAN_BASE_URL=https://yourcompany.atlassian.net
ATLASSIAN_EMAIL=your-email@company.com
ATLASSIAN_API_TOKEN=your-api-token-here

# Veracode SAST scanning (optional — tools are disabled if these are not set)
VERACODE_API_ID=your-veracode-api-id
VERACODE_API_KEY=your-veracode-api-secret-key
VERACODE_APP_NAME=media-services-pocredirector-pocredirector

# GitHub integration for veracode_find_scan_for_pr (optional)
# GITHUB_TOKEN: a personal access token or fine-grained PAT with Actions:read and Contents:read
# GITHUB_REPO: the repository in owner/repo format
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO=inContact/POCR

# SonarQube integration (optional — tools are disabled if these are not set)
# SONARQUBE_TOKEN: generate from SonarQube UI > My Account > Security > Generate Tokens
SONARQUBE_BASE_URL=https://sonar.nice.com
SONARQUBE_TOKEN=your-sonarqube-user-token
SONARQUBE_PROJECT_KEY=your-project-key

# Auto-detect current Git branch (optional — used by Veracode and SonarQube tools)
# Set to the local path of the repo so tools can auto-detect the branch without the user specifying it
GIT_REPO_PATH=C:\Users\pbora\OneDrive - NICE Ltd\Documents\POCR
