ATLASSIAN_BASE_URL=https://yourcompany.atlassian.net
ATLASSIAN_EMAIL=your-email@company.com
ATLASSIAN_API_TOKEN=your-api-token-here

# Veracode SAST scanning (optional — tools are disabled if these are not set)
VERACODE_API_ID=your-veracode-api-id
VERACODE_API_KEY=your-veracode-api-secret-key
VERACODE_APP_NAME=your-veracode-app-name

# GitHub integration for veracode_find_scan_for_pr (optional)
# GITHUB_TOKEN: a personal access token or fine-grained PAT with Actions:read and Contents:read
# GITHUB_REPO: the repository in owner/repo format
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO=your-github-repo

# SonarQube integration via the official SonarQube MCP server (Docker image mcp/sonarqube)
# Requires Docker to be running. Tools are disabled if SONARQUBE_TOKEN is not set.
# SONARQUBE_TOKEN: generate from SonarQube UI > My Account > Security > Generate Tokens (must be USER type)
# SONARQUBE_URL:   your SonarQube Server URL (omit for SonarQube Cloud, which defaults to https://sonarcloud.io)
#                  use https://sonarqube.us for SonarQube Cloud US region
# SONARQUBE_ORG:   organisation key — set this for SonarQube Cloud; omit for SonarQube Server
SONARQUBE_TOKEN=your-sonarqube-user-token
SONARQUBE_URL=https://sonar.nice.com
# SONARQUBE_ORG=your-org-key
# SONARQUBE_PROJECT_KEY=your-default-project-key
# SONARQUBE_READ_ONLY=true
# TELEMETRY_DISABLED=true

# Aikido Security integration via the official Aikido MCP server (npx @aikidosec/mcp)
# Tools are disabled if AIKIDO_API_KEY is not set.
# Generate at: Aikido dashboard → Settings → Integrations → Public REST API
AIKIDO_API_KEY=your-aikido-api-key

# Custom Aikido REST tools (aikido_list_repos, aikido_get_issues) via the Aikido Public REST API.
# Tools are disabled if AIKIDO_CLIENT_ID or AIKIDO_CLIENT_SECRET is not set.
# Generate at: Aikido dashboard → Settings → Integrations → Public REST API → Create client
AIKIDO_CLIENT_ID=your-aikido-client-id
AIKIDO_CLIENT_SECRET=your-aikido-client-secret
# Optional: default repo name used when aikido_get_issues is called without repoName/repoId
AIKIDO_DEFAULT_REPO_NAME=your-default-repo-name

# Auto-detect current Git branch (optional — used by Veracode and SonarQube tools)
# Set to the local path of the repo so tools can auto-detect the branch without the user specifying it
GIT_REPO_PATH=your-local-repo-path
